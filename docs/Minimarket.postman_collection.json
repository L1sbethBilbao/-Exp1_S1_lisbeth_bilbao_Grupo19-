      "item": [
        {
          "name": "GET Listar ventas",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/ventas",
            "description": "GET /api/ventas\n\nCLIENTE: solo sus ventas.\nEMPLEADO/GERENTE: todas."
