          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"usuario\": { \"id\": 1 },\n  \"fecha\": \"2026-05-24T12:00:00.000+00:00\",\n  \"detalles\": [\n    {\n      \"producto\": { \"id\": 2 },\n      \"cantidad\": 1,\n      \"precio\": 1200\n    }\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/ventas",
            "description": "POST /api/ventas\n\nVenta con detalles anidados (como en DataInitializer).\nCLIENTE: usuario forzado al logueado."
          },
          "response": []
        }
      ]
    },
    {
      "name": "06 - Inventario",
      "description": "Base: /api/inventario\n\nSolo EMPLEADO y GERENTE.",
      "item": [
        {
          "name": "GET Listar inventario",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/inventario",
            "description": "GET /api/inventario\n\nRoles: EMPLEADO, GERENTE.\nEsperado: 200 | 403 CLIENTE | 401 sin sesion"
          },
          "response": []
        },
        {
          "name": "GET Inventario por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/inventario/{{inventarioId}}",
            "description": "GET /api/inventario/{id}\n\nEsperado: 200 | 404 | 403 CLIENTE"
          },
          "response": []
        },
        {
          "name": "POST Registrar movimiento",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"producto\": { \"id\": 1 },\n  \"cantidad\": 10,\n  \"tipoMovimiento\": \"Entrada\",\n  \"fechaMovimiento\": \"2026-05-24T12:00:00.000+00:00\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/inventario",
            "description": "POST /api/inventario\n\nBody: producto, cantidad, tipoMovimiento (Entrada/Salida), fechaMovimiento."
          },
          "response": []
        },
