          },
          "response": []
        }
      ]
    },
    {
      "name": "04 - Carrito",
      "description": "Base: /api/carrito\n\nCLIENTE: solo su carrito (IDOR). EMPLEADO/GERENTE: acceso total.",
      "item": [
        {
          "name": "GET Listar carrito",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/carrito",
            "description": "GET /api/carrito\n\nCLIENTE: solo sus items.\nEMPLEADO/GERENTE: todos los items."
          },
          "response": []
        },
        {
          "name": "GET Carrito por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/carrito/{{carritoId}}",
            "description": "GET /api/carrito/{id}\n\nCLIENTE: 403 si el carrito es de otro usuario.\nEsperado: 200 | 403 | 404"
          },
          "response": []
        },
        {
          "name": "POST Agregar al carrito",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"usuario\": { \"id\": 1 },\n  \"producto\": { \"id\": 3 },\n  \"cantidad\": 1\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/carrito",
            "description": "POST /api/carrito\n\nCLIENTE: el usuario se fuerza al logueado (IDOR).\nBody: usuario, producto (por id), cantidad (min 1)."
          },
          "response": []
        },
        {
          "name": "PUT Actualizar carrito",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"usuario\": { \"id\": 1 },\n  \"producto\": { \"id\": 1 },\n  \"cantidad\": 3\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/carrito/{{carritoId}}",
            "description": "PUT /api/carrito/{id}\n\nCLIENTE: 403 si no es su carrito."
          },
          "response": []
        },
        {
          "name": "DELETE Eliminar del carrito",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/api/carrito/{{carritoId}}",
            "description": "DELETE /api/carrito/{id}\n\nEsperado: 204 | 403 | 404"
          },
          "response": []
        }
      ]
    },
    {
